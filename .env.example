# Supabase direct Postgres connection (Project Settings > Database > Connection string > URI)
DATABASE_URL=
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Supabase Storage (server-side only — used by /api/upload, never exposed to the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (server-side only — no EXPO_PUBLIC prefix so it stays out of the client bundle)
GEMINI_API_KEY=